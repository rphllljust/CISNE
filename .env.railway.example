# ─── Backend (serviço: backend) ───────────────────────────────────────────────
# Preenchido automaticamente pelo Railway ao adicionar PostgreSQL:
DATABASE_URL=${{Postgres.DATABASE_URL}}

NODE_ENV=production
PORT=3000
API_PREFIX=api/v1
TRUST_PROXY=true

# CORS: coloque a URL pública do frontend (gerada pelo Railway)
CORS_ORIGIN=https://frontend-production-xxxx.up.railway.app

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_CHARS_HEX
JWT_REFRESH_SECRET=CHANGE_ME_64_CHARS_HEX
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_EXPIRES_MINUTES=60

LOG_LEVEL=info

# Opcionais — Módulo 4 (WhatsApp/SMS)
# WHATSAPP_API_URL=https://graph.facebook.com/v19.0/PHONE_NUMBER_ID/messages
# WHATSAPP_API_TOKEN=YOUR_WHATSAPP_TOKEN
# SMS_API_URL=https://api.twilio.com/2010-04-01/Accounts/SID/Messages.json
# SMS_API_TOKEN=YOUR_TWILIO_TOKEN

# URL pública do app (para links nos templates de WhatsApp)
# APP_BASE_URL=https://frontend-production-xxxx.up.railway.app

# ─── Frontend (serviço: frontend) ─────────────────────────────────────────────
# BACKEND_URL=https://backend-production-xxxx.up.railway.app
# (ou use Railway Private Networking: o Dockerfile detecta BACKEND_RAILWAY_PRIVATE_DOMAIN automaticamente)

# ─── Migrator (serviço: migrator) ─────────────────────────────────────────────
# DATABASE_URL=${{Postgres.DATABASE_URL}}
