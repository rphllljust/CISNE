# ----------------------------------------------------------------------------
# OMS Production Environment
# ----------------------------------------------------------------------------

# Edge / TLS
APP_DOMAIN=oms.seudominio.com
CADDY_EMAIL=devops@seudominio.com

# Application
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=https://oms.seudominio.com
TRUST_PROXY=true
LOG_LEVEL=info

# Database
POSTGRES_USER=oms
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=oms
DATABASE_URL=postgresql://oms:change_this_password@postgres:5432/oms?schema=public

# Auth
JWT_ACCESS_SECRET=change_this_with_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_with_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_EXPIRES_MINUTES=30
