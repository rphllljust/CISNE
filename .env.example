# =========================
# DEVELOPMENT (local)
# =========================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1`nSWAGGER_PATH=docs
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=false
LOG_LEVEL=debug

DATABASE_URL=postgresql://oms_dev:${DEV_DB_PASSWORD}@localhost:5432/oms_dev?schema=public

JWT_ACCESS_SECRET=DEV_ONLY_GENERATE_AT_LEAST_32_CHARS_RANDOM_123!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=DEV_ONLY_DIFFERENT_RANDOM_32PLUS_SECRET_456!
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_EXPIRES_MINUTES=30
ENABLE_DEV_RESET_TOKEN_LOG=false

# Optional integrations (set both or none)
SMTP_USER=
SMTP_PASSWORD=

# =========================
# HOMOLOGATION (strict)
# =========================
# NODE_ENV=test
# CORS_ORIGIN=https://hmg.app.seudominio.com
# DATABASE_URL=postgresql://oms_hmg:${HMG_DB_PASSWORD}@db-hmg.internal:5432/oms_hmg?schema=public
# JWT_ACCESS_SECRET=<RANDOM_32PLUS_NO_DEFAULT_WORDS>
# JWT_REFRESH_SECRET=<RANDOM_32PLUS_DIFFERENT_FROM_ACCESS>

# =========================
# PRODUCTION (strict)
# =========================
# NODE_ENV=production
# CORS_ORIGIN=https://app.seudominio.com,https://ops.seudominio.com
# DATABASE_URL=postgresql://oms:${PROD_DB_PASSWORD}@db-prod.internal:5432/oms?schema=public
# JWT_ACCESS_SECRET=<RANDOM_32PLUS_NO_DEFAULT_WORDS>
# JWT_REFRESH_SECRET=<RANDOM_32PLUS_DIFFERENT_FROM_ACCESS>
# ENABLE_DEV_RESET_TOKEN_LOG=false


APP_VERSION=1.0.0

