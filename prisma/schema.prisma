generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ClientType {
  INDIVIDUAL
  BUSINESS
}

enum ContractStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ServiceOrderStatus {
  OPEN
  UNDER_ANALYSIS
  WAITING_APPROVAL
  SCHEDULED
  IN_TRANSIT
  IN_PROGRESS
  PAUSED
  WAITING_PARTS
  WAITING_CUSTOMER
  COMPLETED
  CANCELED
  REOPENED
}

enum AttachmentCategory {
  BEFORE
  AFTER
  DOCUMENT
  SIGNATURE
  OTHER
}

enum CommentVisibility {
  INTERNAL
  CLIENT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum ScheduleConfirmationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model User {
  id                     String                     @id @default(uuid())
  email                  String                     @unique
  passwordHash           String
  fullName               String
  phone                  String?
  avatarUrl              String?
  jobTitle               String?
  department             String?
  status                 UserStatus                 @default(ACTIVE)
  supervisedTeams        Team[]                     @relation("TeamSupervisor")
  teamMemberships        TeamMember[]
  userRoles              UserRole[]
  createdServiceOrders   ServiceOrder[]             @relation("CreatedBy")
  updatedServiceOrders   ServiceOrder[]             @relation("UpdatedBy")
  assignedServiceOrders  ServiceOrder[]             @relation("AssignedTechnician")
  changedStatuses        ServiceOrderStatusHistory[] @relation("StatusChangedBy")
  checkedChecklistItems  ServiceOrderChecklistItem[] @relation("ChecklistCheckedBy")
  comments               Comment[]
  attachments            Attachment[]
  notifications          Notification[]
  auditLogs              AuditLog[]                 @relation("AuditActor")
  loginHistories         LoginHistory[]
  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  schedules              Schedule[]                 @relation("ScheduledTechnician")
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  deletedAt              DateTime?

  @@index([status])
  @@index([deletedAt])
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  isSystem        Boolean          @default(true)
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Permission {
  id              String           @id @default(uuid())
  code            String           @unique
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model Client {
  id            String         @id @default(uuid())
  type          ClientType
  name          String
  legalName     String?
  taxId         String         @unique
  email         String?
  phone         String?
  mobile        String?
  contactName   String?
  notes         String?
  active        Boolean        @default(true)
  addresses     Address[]
  contracts     Contract[]
  serviceOrders ServiceOrder[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  @@index([name])
  @@index([taxId])
  @@index([deletedAt])
}

model Address {
  id                  String         @id @default(uuid())
  clientId            String?
  label               String?
  street              String
  number              String
  complement          String?
  district            String
  city                String
  state               String
  zipCode             String
  country             String         @default("Brasil")
  latitude            Decimal?       @db.Decimal(10, 7)
  longitude           Decimal?       @db.Decimal(10, 7)
  isPrimary           Boolean        @default(false)
  client              Client?        @relation(fields: [clientId], references: [id])
  serviceOrders       ServiceOrder[] @relation("ServiceOrderLocation")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([clientId])
  @@index([city, state])
}

model SLA {
  id                      String        @id @default(uuid())
  name                    String
  responseTimeMinutes     Int
  resolutionTimeMinutes   Int
  warningBeforeMinutes    Int           @default(60)
  description             String?
  active                  Boolean       @default(true)
  serviceTypes            ServiceType[]
  contracts               Contract[]
  serviceOrders           ServiceOrder[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@unique([name])
  @@index([active])
}

model Contract {
  id                String         @id @default(uuid())
  clientId          String
  slaId             String?
  code              String         @unique
  title             String
  status            ContractStatus @default(DRAFT)
  startDate         DateTime
  endDate           DateTime?
  serviceScope      String?
  monthlyQuota      Int?
  client            Client         @relation(fields: [clientId], references: [id])
  sla               SLA?           @relation(fields: [slaId], references: [id])
  serviceOrders     ServiceOrder[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([clientId])
  @@index([status])
}

model ServiceCategory {
  id            String        @id @default(uuid())
  code          String        @unique
  name          String
  description   String?
  active        Boolean       @default(true)
  serviceTypes  ServiceType[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([active])
  @@index([name])
}

model ServiceType {
  id                       String        @id @default(uuid())
  categoryId               String
  defaultSlaId             String?
  code                     String        @unique
  name                     String
  subcategory              String?
  description              String?
  defaultPriority          Priority      @default(MEDIUM)
  estimatedDurationMinutes Int
  checklistTemplate        Json?
  executionRules           Json?
  active                   Boolean       @default(true)
  category                 ServiceCategory @relation(fields: [categoryId], references: [id])
  defaultSla               SLA?          @relation(fields: [defaultSlaId], references: [id])
  serviceOrders            ServiceOrder[]
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  @@index([categoryId])
  @@index([defaultSlaId])
  @@index([active])
}

model Team {
  id             String         @id @default(uuid())
  code           String         @unique
  name           String
  region         String?
  supervisorId   String?
  active         Boolean        @default(true)
  supervisor     User?          @relation("TeamSupervisor", fields: [supervisorId], references: [id])
  members        TeamMember[]
  assignedOrders ServiceOrder[] @relation("AssignedTeam")
  schedules      Schedule[]     @relation("ScheduledTeam")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([supervisorId])
  @@index([active])
}

model TeamMember {
  id             String   @id @default(uuid())
  teamId         String
  userId         String
  specialty      String?
  isLead         Boolean  @default(false)
  availability   Json?
  regionCoverage String?
  active         Boolean  @default(true)
  team           Team     @relation(fields: [teamId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([userId])
  @@index([active])
}

model ServiceOrder {
  id                  String                     @id @default(uuid())
  orderNumber         Int                        @unique @default(autoincrement())
  clientId            String
  serviceTypeId       String
  contractId          String?
  slaId               String?
  assignedTeamId      String?
  assignedTechnicianId String?
  locationAddressId   String?
  title               String
  description         String
  priority            Priority                   @default(MEDIUM)
  status              ServiceOrderStatus         @default(OPEN)
  openedAt            DateTime                   @default(now())
  scheduledStartAt    DateTime?
  scheduledEndAt      DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  canceledAt          DateTime?
  windowStart         DateTime?
  windowEnd           DateTime?
  internalNotes       String?
  customerNotes       String?
  cancellationReason  String?
  slaDueAt            DateTime?
  slaBreached         Boolean                    @default(false)
  reopenedCount       Int                        @default(0)
  createdById         String
  updatedById         String?
  deletedAt           DateTime?
  client              Client                     @relation(fields: [clientId], references: [id])
  serviceType         ServiceType                @relation(fields: [serviceTypeId], references: [id])
  contract            Contract?                  @relation(fields: [contractId], references: [id])
  sla                 SLA?                       @relation(fields: [slaId], references: [id])
  assignedTeam        Team?                      @relation("AssignedTeam", fields: [assignedTeamId], references: [id])
  assignedTechnician  User?                      @relation("AssignedTechnician", fields: [assignedTechnicianId], references: [id])
  locationAddress     Address?                   @relation("ServiceOrderLocation", fields: [locationAddressId], references: [id])
  createdBy           User                       @relation("CreatedBy", fields: [createdById], references: [id])
  updatedBy           User?                      @relation("UpdatedBy", fields: [updatedById], references: [id])
  statusHistory       ServiceOrderStatusHistory[]
  checklistItems      ServiceOrderChecklistItem[]
  comments            Comment[]
  attachments         Attachment[]
  schedules           Schedule[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([status])
  @@index([priority])
  @@index([clientId])
  @@index([serviceTypeId])
  @@index([assignedTeamId])
  @@index([assignedTechnicianId])
  @@index([openedAt])
  @@index([slaDueAt])
  @@index([deletedAt])
}

model ServiceOrderStatusHistory {
  id             String              @id @default(uuid())
  serviceOrderId String
  fromStatus     ServiceOrderStatus?
  toStatus       ServiceOrderStatus
  reason         String?
  metadata       Json?
  changedById    String
  changedAt      DateTime            @default(now())
  serviceOrder   ServiceOrder        @relation(fields: [serviceOrderId], references: [id])
  changedBy      User                @relation("StatusChangedBy", fields: [changedById], references: [id])

  @@index([serviceOrderId, changedAt])
  @@index([toStatus])
}

model ServiceOrderChecklistItem {
  id                   String      @id @default(uuid())
  serviceOrderId       String
  itemKey              String
  description          String
  required             Boolean     @default(false)
  checked              Boolean     @default(false)
  checkedAt            DateTime?
  checkedById          String?
  evidenceAttachmentId String?
  serviceOrder         ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  checkedBy            User?       @relation("ChecklistCheckedBy", fields: [checkedById], references: [id])
  evidenceAttachment   Attachment? @relation("ChecklistEvidence", fields: [evidenceAttachmentId], references: [id])
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@unique([serviceOrderId, itemKey])
  @@index([checked])
}

model Comment {
  id             String            @id @default(uuid())
  serviceOrderId String
  authorId       String
  visibility     CommentVisibility @default(INTERNAL)
  message        String
  serviceOrder   ServiceOrder      @relation(fields: [serviceOrderId], references: [id])
  author         User              @relation(fields: [authorId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([serviceOrderId, createdAt])
}

model Attachment {
  id                 String                     @id @default(uuid())
  serviceOrderId     String?
  uploaderId         String
  fileName           String
  originalFileName   String
  mimeType           String
  sizeBytes          Int
  storageProvider    String                     @default("local")
  storagePath        String
  checksum           String?
  category           AttachmentCategory         @default(DOCUMENT)
  metadata           Json?
  serviceOrder       ServiceOrder?              @relation(fields: [serviceOrderId], references: [id])
  uploader           User                       @relation(fields: [uploaderId], references: [id])
  checklistEvidences ServiceOrderChecklistItem[] @relation("ChecklistEvidence")
  createdAt          DateTime                   @default(now())

  @@index([serviceOrderId])
  @@index([uploaderId])
  @@index([category])
}

model Schedule {
  id                  String                     @id @default(uuid())
  serviceOrderId      String
  teamId              String?
  technicianId        String?
  scheduledStart      DateTime
  scheduledEnd        DateTime
  windowStart         DateTime?
  windowEnd           DateTime?
  routeSequence       Int?
  travelDurationMinutes Int?
  delayMinutes        Int                        @default(0)
  confirmationStatus  ScheduleConfirmationStatus @default(PENDING)
  confirmedAt         DateTime?
  checkInAt           DateTime?
  checkOutAt          DateTime?
  notes               String?
  rescheduledFromId   String?
  serviceOrder        ServiceOrder               @relation(fields: [serviceOrderId], references: [id])
  team                Team?                      @relation("ScheduledTeam", fields: [teamId], references: [id])
  technician          User?                      @relation("ScheduledTechnician", fields: [technicianId], references: [id])
  rescheduledFrom     Schedule?                  @relation("ScheduleReschedule", fields: [rescheduledFromId], references: [id])
  reschedules         Schedule[]                 @relation("ScheduleReschedule")
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([serviceOrderId])
  @@index([teamId])
  @@index([technicianId])
  @@index([scheduledStart, scheduledEnd])
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  type      String
  channel   NotificationChannel
  status    NotificationStatus @default(PENDING)
  title     String
  message   String
  payload   Json?
  sentAt    DateTime?
  readAt    DateTime?
  user      User               @relation(fields: [userId], references: [id])
  createdAt DateTime           @default(now())

  @@index([userId, status])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  action    String
  resource  String
  resourceId String?
  before    Json?
  after     Json?
  metadata  Json?
  ip        String?
  userAgent String?
  severity  String   @default("INFO")
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id])
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([resource, resourceId])
  @@index([action])
  @@index([createdAt])
}

model LoginHistory {
  id            String   @id @default(uuid())
  userId        String?
  email         String
  ip            String?
  userAgent     String?
  success       Boolean
  failureReason String?
  user          User?    @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())

  @@index([email])
  @@index([success])
  @@index([createdAt])
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  replacedById String?
  ip          String?
  userAgent   String?
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([userId, revokedAt])
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
