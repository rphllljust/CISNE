generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ClientType {
  INDIVIDUAL
  BUSINESS
}

enum ContractStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ServiceOrderStatus {
  OPEN
  UNDER_ANALYSIS
  WAITING_APPROVAL
  SCHEDULED
  IN_TRANSIT
  IN_PROGRESS
  PAUSED
  WAITING_PARTS
  WAITING_CUSTOMER
  COMPLETED
  CANCELED
  REOPENED
}

enum AttachmentCategory {
  BEFORE
  AFTER
  DOCUMENT
  SIGNATURE
  OTHER
}

enum CommentVisibility {
  INTERNAL
  CLIENT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum ScheduleConfirmationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model User {
  id                    String                      @id @default(uuid())
  email                 String                      @unique
  passwordHash          String
  fullName              String
  phone                 String?
  avatarUrl             String?
  jobTitle              String?
  department            String?
  status                UserStatus                  @default(ACTIVE)
  supervisedTeams       Team[]                      @relation("TeamSupervisor")
  teamMemberships       TeamMember[]
  userRoles             UserRole[]
  createdServiceOrders  ServiceOrder[]              @relation("CreatedBy")
  updatedServiceOrders  ServiceOrder[]              @relation("UpdatedBy")
  assignedServiceOrders ServiceOrder[]              @relation("AssignedTechnician")
  changedStatuses       ServiceOrderStatusHistory[] @relation("StatusChangedBy")
  checkedChecklistItems ServiceOrderChecklistItem[] @relation("ChecklistCheckedBy")
  comments              Comment[]
  attachments           Attachment[]
  notifications         Notification[]
  auditLogs             AuditLog[]                  @relation("AuditActor")
  loginHistories        LoginHistory[]
  refreshTokens         RefreshToken[]
  passwordResetTokens   PasswordResetToken[]
  schedules                  Schedule[]                  @relation("ScheduledTechnician")
  budgetApprovedOrders       ServiceOrder[]              @relation("BudgetApprovedBy")
  createdDocumentExtractions DocumentExtraction[]        @relation("ExtractionCreatedBy")
  correctedExtractions       DocumentExtraction[]        @relation("ExtractionCorrectedBy")
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  deletedAt                  DateTime?

  @@index([status])
  @@index([deletedAt])
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  isSystem        Boolean          @default(true)
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Permission {
  id              String           @id @default(uuid())
  code            String           @unique
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model Client {
  id            String         @id @default(uuid())
  type          ClientType
  name          String
  legalName     String?
  taxId         String         @unique
  email         String?
  phone         String?
  mobile        String?
  contactName   String?
  notes         String?
  active        Boolean        @default(true)
  addresses     Address[]
  contracts     Contract[]
  serviceOrders ServiceOrder[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  @@index([name])
  @@index([taxId])
  @@index([deletedAt])
}

model Address {
  id            String         @id @default(uuid())
  clientId      String?
  label         String?
  street        String
  number        String
  complement    String?
  district      String
  city          String
  state         String
  zipCode       String
  country       String         @default("Brasil")
  latitude      Decimal?       @db.Decimal(10, 7)
  longitude     Decimal?       @db.Decimal(10, 7)
  isPrimary     Boolean        @default(false)
  client        Client?        @relation(fields: [clientId], references: [id])
  serviceOrders ServiceOrder[] @relation("ServiceOrderLocation")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([clientId])
  @@index([city, state])
}

model SLA {
  id                    String         @id @default(uuid())
  name                  String
  responseTimeMinutes   Int
  resolutionTimeMinutes Int
  warningBeforeMinutes  Int            @default(60)
  description           String?
  active                Boolean        @default(true)
  serviceTypes          ServiceType[]
  contracts             Contract[]
  serviceOrders         ServiceOrder[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@unique([name])
  @@index([active])
}

model Contract {
  id            String         @id @default(uuid())
  clientId      String
  slaId         String?
  code          String         @unique
  title         String
  status        ContractStatus @default(DRAFT)
  startDate     DateTime
  endDate       DateTime?
  serviceScope  String?
  monthlyQuota  Int?
  client        Client         @relation(fields: [clientId], references: [id])
  sla           SLA?           @relation(fields: [slaId], references: [id])
  serviceOrders ServiceOrder[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([clientId])
  @@index([status])
}

model ServiceCategory {
  id           String        @id @default(uuid())
  code         String        @unique
  name         String
  description  String?
  active       Boolean       @default(true)
  serviceTypes ServiceType[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([active])
  @@index([name])
}

model ServiceType {
  id                       String          @id @default(uuid())
  categoryId               String
  defaultSlaId             String?
  code                     String          @unique
  name                     String
  subcategory              String?
  description              String?
  defaultPriority          Priority        @default(MEDIUM)
  estimatedDurationMinutes Int
  checklistTemplate        Json?
  executionRules           Json?
  active                   Boolean         @default(true)
  category                 ServiceCategory @relation(fields: [categoryId], references: [id])
  defaultSla               SLA?            @relation(fields: [defaultSlaId], references: [id])
  serviceOrders            ServiceOrder[]
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  @@index([categoryId])
  @@index([defaultSlaId])
  @@index([active])
}

model Team {
  id             String         @id @default(uuid())
  code           String         @unique
  name           String
  region         String?
  supervisorId   String?
  active         Boolean        @default(true)
  supervisor     User?          @relation("TeamSupervisor", fields: [supervisorId], references: [id])
  members        TeamMember[]
  assignedOrders ServiceOrder[] @relation("AssignedTeam")
  schedules      Schedule[]     @relation("ScheduledTeam")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([supervisorId])
  @@index([active])
}

model TeamMember {
  id             String   @id @default(uuid())
  teamId         String
  userId         String
  specialty      String?
  isLead         Boolean  @default(false)
  availability   Json?
  regionCoverage String?
  active         Boolean  @default(true)
  team           Team     @relation(fields: [teamId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([userId])
  @@index([active])
}

model ServiceOrder {
  id                   String                      @id @default(uuid())
  orderNumber          Int                         @unique @default(autoincrement())
  clientId             String
  serviceTypeId        String
  contractId           String?
  slaId                String?
  assignedTeamId       String?
  assignedTechnicianId String?
  locationAddressId    String?
  title                String
  description          String
  priority             Priority                    @default(MEDIUM)
  status               ServiceOrderStatus          @default(OPEN)
  openedAt             DateTime                    @default(now())
  scheduledStartAt     DateTime?
  scheduledEndAt       DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  canceledAt           DateTime?
  windowStart          DateTime?
  windowEnd            DateTime?
  internalNotes        String?
  customerNotes        String?
  cancellationReason   String?
  slaDueAt                DateTime?
  slaDeadline             DateTime?
  slaBreached             Boolean                     @default(false)
  reopenedCount           Int                         @default(0)
  estimatedValue          Decimal?                    @db.Decimal(12, 2)
  // Automação (MÓDULO 2)
  autoCreated             Boolean                     @default(false)
  sourceExtractionId      String?
  budgetRequiresApproval  Boolean                     @default(false)
  budgetApprovalStatus    String?
  budgetApprovedById      String?
  budgetApprovedAt        DateTime?
  budgetRejectionReason   String?
  createdById             String
  updatedById             String?
  deletedAt               DateTime?
  client                  Client                      @relation(fields: [clientId], references: [id])
  serviceType             ServiceType                 @relation(fields: [serviceTypeId], references: [id])
  contract                Contract?                   @relation(fields: [contractId], references: [id])
  sla                     SLA?                        @relation(fields: [slaId], references: [id])
  assignedTeam            Team?                       @relation("AssignedTeam", fields: [assignedTeamId], references: [id])
  assignedTechnician      User?                       @relation("AssignedTechnician", fields: [assignedTechnicianId], references: [id])
  locationAddress         Address?                    @relation("ServiceOrderLocation", fields: [locationAddressId], references: [id])
  createdBy               User                        @relation("CreatedBy", fields: [createdById], references: [id])
  updatedBy               User?                       @relation("UpdatedBy", fields: [updatedById], references: [id])
  budgetApprovedBy        User?                       @relation("BudgetApprovedBy", fields: [budgetApprovedById], references: [id])
  statusHistory           ServiceOrderStatusHistory[]
  checklistItems          ServiceOrderChecklistItem[]
  comments                Comment[]
  attachments             Attachment[]
  schedules               Schedule[]
  documentExtractions     DocumentExtraction[]
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  @@index([status])
  @@index([priority])
  @@index([clientId])
  @@index([serviceTypeId])
  @@index([assignedTeamId])
  @@index([assignedTechnicianId])
  @@index([openedAt])
  @@index([slaDueAt])
  @@index([deletedAt])
  @@index([autoCreated])
  @@index([budgetApprovalStatus])
}

model ServiceOrderStatusHistory {
  id             String              @id @default(uuid())
  serviceOrderId String
  fromStatus     ServiceOrderStatus?
  toStatus       ServiceOrderStatus
  reason         String?
  metadata       Json?
  changedById    String
  changedAt      DateTime            @default(now())
  serviceOrder   ServiceOrder        @relation(fields: [serviceOrderId], references: [id])
  changedBy      User                @relation("StatusChangedBy", fields: [changedById], references: [id])

  @@index([serviceOrderId, changedAt])
  @@index([toStatus])
}

model ServiceOrderChecklistItem {
  id                   String       @id @default(uuid())
  serviceOrderId       String
  itemKey              String
  description          String
  required             Boolean      @default(false)
  checked              Boolean      @default(false)
  checkedAt            DateTime?
  checkedById          String?
  evidenceAttachmentId String?
  serviceOrder         ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  checkedBy            User?        @relation("ChecklistCheckedBy", fields: [checkedById], references: [id])
  evidenceAttachment   Attachment?  @relation("ChecklistEvidence", fields: [evidenceAttachmentId], references: [id])
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([serviceOrderId, itemKey])
  @@index([checked])
}

model Comment {
  id             String            @id @default(uuid())
  serviceOrderId String
  authorId       String
  visibility     CommentVisibility @default(INTERNAL)
  message        String
  serviceOrder   ServiceOrder      @relation(fields: [serviceOrderId], references: [id])
  author         User              @relation(fields: [authorId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([serviceOrderId, createdAt])
}

model Attachment {
  id                 String                      @id @default(uuid())
  serviceOrderId     String?
  uploaderId         String
  fileName           String
  originalFileName   String
  mimeType           String
  sizeBytes          Int
  storageProvider    String                      @default("local")
  storagePath        String
  checksum           String?
  category           AttachmentCategory          @default(DOCUMENT)
  metadata           Json?
  serviceOrder       ServiceOrder?               @relation(fields: [serviceOrderId], references: [id])
  uploader           User                        @relation(fields: [uploaderId], references: [id])
  checklistEvidences ServiceOrderChecklistItem[] @relation("ChecklistEvidence")
  createdAt          DateTime                    @default(now())

  @@index([serviceOrderId])
  @@index([uploaderId])
  @@index([category])
}

model Schedule {
  id                    String                     @id @default(uuid())
  serviceOrderId        String
  teamId                String?
  technicianId          String?
  scheduledStart        DateTime
  scheduledEnd          DateTime
  windowStart           DateTime?
  windowEnd             DateTime?
  routeSequence         Int?
  travelDurationMinutes Int?
  delayMinutes          Int                        @default(0)
  confirmationStatus    ScheduleConfirmationStatus @default(PENDING)
  confirmedAt           DateTime?
  checkInAt             DateTime?
  checkOutAt            DateTime?
  notes                 String?
  rescheduledFromId     String?
  serviceOrder          ServiceOrder               @relation(fields: [serviceOrderId], references: [id])
  team                  Team?                      @relation("ScheduledTeam", fields: [teamId], references: [id])
  technician            User?                      @relation("ScheduledTechnician", fields: [technicianId], references: [id])
  rescheduledFrom       Schedule?                  @relation("ScheduleReschedule", fields: [rescheduledFromId], references: [id])
  reschedules           Schedule[]                 @relation("ScheduleReschedule")
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  @@index([serviceOrderId])
  @@index([teamId])
  @@index([technicianId])
  @@index([scheduledStart, scheduledEnd])
}

model Notification {
  id        String              @id @default(uuid())
  userId    String?
  type      String
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  title     String
  message   String
  payload   Json?
  sentAt    DateTime?
  readAt    DateTime?
  user      User?               @relation(fields: [userId], references: [id])
  createdAt DateTime            @default(now())

  @@index([userId, status])
  @@index([createdAt])
  @@index([channel, status])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  resource   String
  resourceId String?
  before     Json?
  after      Json?
  metadata   Json?
  ip         String?
  userAgent  String?
  severity   String   @default("INFO")
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([resource, resourceId])
  @@index([action])
  @@index([createdAt])
}

model LoginHistory {
  id            String   @id @default(uuid())
  userId        String?
  email         String
  ip            String?
  userAgent     String?
  success       Boolean
  failureReason String?
  user          User?    @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())

  @@index([email])
  @@index([success])
  @@index([createdAt])
}

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  ip           String?
  userAgent    String?
  user         User      @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now())

  @@index([userId, revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

enum AssetStatus {
  IN_STOCK
  IN_USE
  MAINTENANCE
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AssetMaintenanceType {
  PREVENTIVE
  CORRECTIVE
  INSPECTION
  CALIBRATION
}

enum AssetMaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum InventoryTransactionType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
  TRANSFER
}

enum SupplierContractStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELED
}

enum KnowledgeArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum ProblemStatus {
  OPEN
  UNDER_INVESTIGATION
  KNOWN_ERROR
  RESOLVED
  CLOSED
}

enum ChangeCategory {
  STANDARD
  NORMAL
  EMERGENCY
}

enum ChangeStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  SCHEDULED
  IMPLEMENTING
  REVIEW
  COMPLETED
  CANCELED
}

enum ChangeRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Supplier {
  id          String             @id @default(uuid())
  name        String
  legalName   String?
  taxId       String             @unique
  email       String?
  phone       String?
  contactName String?
  notes       String?
  active      Boolean            @default(true)
  assets      Asset[]
  contracts   SupplierContract[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?

  @@index([name])
  @@index([active])
  @@index([deletedAt])
}

model SupplierContract {
  id               String                 @id @default(uuid())
  supplierId       String
  contractCode     String
  title            String
  status           SupplierContractStatus @default(DRAFT)
  startDate        DateTime
  endDate          DateTime?
  monthlyValue     Decimal?               @db.Decimal(12, 2)
  renewalAlertDays Int                    @default(30)
  notes            String?
  supplier         Supplier               @relation(fields: [supplierId], references: [id])
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([supplierId])
  @@index([status])
  @@index([endDate])
}

model Asset {
  id                    String                  @id @default(uuid())
  code                  String                  @unique
  name                  String
  description           String?
  serialNumber          String?                 @unique
  category              String
  brand                 String?
  model                 String?
  status                AssetStatus             @default(IN_STOCK)
  condition             AssetCondition          @default(GOOD)
  acquisitionDate       DateTime?
  acquisitionCost       Decimal?                @db.Decimal(12, 2)
  warrantyUntil         DateTime?
  depreciationEndDate   DateTime?
  location              String?
  clientId              String?
  contractId            String?
  supplierId            String?
  assignedTeamId        String?
  assignedTechnicianId  String?
  nextPreventiveAt      DateTime?
  lastMaintenanceAt     DateTime?
  active                Boolean                 @default(true)
  supplier              Supplier?               @relation(fields: [supplierId], references: [id])
  maintenances          AssetMaintenance[]
  inventoryTransactions InventoryTransaction[]
  serviceOrderLinks     ServiceOrderAssetLink[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  deletedAt             DateTime?

  @@index([category])
  @@index([status])
  @@index([supplierId])
  @@index([clientId])
  @@index([contractId])
  @@index([assignedTeamId])
  @@index([assignedTechnicianId])
  @@index([active])
  @@index([deletedAt])
}

model AssetMaintenance {
  id            String                 @id @default(uuid())
  assetId       String
  type          AssetMaintenanceType
  status        AssetMaintenanceStatus @default(SCHEDULED)
  scheduledAt   DateTime
  startedAt     DateTime?
  finishedAt    DateTime?
  performedById String?
  description   String?
  cost          Decimal?               @db.Decimal(12, 2)
  notes         String?
  asset         Asset                  @relation(fields: [assetId], references: [id])
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([scheduledAt])
}

model InventoryTransaction {
  id           String                   @id @default(uuid())
  assetId      String
  type         InventoryTransactionType
  quantity     Int                      @default(1)
  fromLocation String?
  toLocation   String?
  reference    String?
  notes        String?
  recordedById String?
  occurredAt   DateTime                 @default(now())
  asset        Asset                    @relation(fields: [assetId], references: [id])
  createdAt    DateTime                 @default(now())

  @@index([assetId, occurredAt])
  @@index([type])
}

model KnowledgeArticle {
  id            String                 @id @default(uuid())
  title         String
  slug          String                 @unique
  summary       String?
  content       String
  status        KnowledgeArticleStatus @default(DRAFT)
  tags          String[]               @default([])
  serviceTypeId String?
  authorId      String?
  reviewerId    String?
  version       Int                    @default(1)
  publishedAt   DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  deletedAt     DateTime?

  @@index([status])
  @@index([serviceTypeId])
  @@index([publishedAt])
  @@index([deletedAt])
}

model ProblemRecord {
  id                    String          @id @default(uuid())
  code                  String          @unique
  title                 String
  description           String
  status                ProblemStatus   @default(OPEN)
  priority              Priority        @default(MEDIUM)
  impact                String?
  rootCause             String?
  workaround            String?
  ownerId               String?
  openedById            String?
  openedAt              DateTime        @default(now())
  resolvedAt            DateTime?
  closedAt              DateTime?
  relatedServiceOrderId String?
  changeRequests        ChangeRequest[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([status])
  @@index([priority])
  @@index([relatedServiceOrderId])
}

model ChangeRequest {
  id                    String          @id @default(uuid())
  code                  String          @unique
  title                 String
  description           String
  category              ChangeCategory  @default(NORMAL)
  status                ChangeStatus    @default(DRAFT)
  riskLevel             ChangeRiskLevel @default(MEDIUM)
  impactAnalysis        String?
  implementationPlan    String?
  rollbackPlan          String?
  requestedById         String?
  approvedById          String?
  approvedAt            DateTime?
  scheduledStartAt      DateTime?
  scheduledEndAt        DateTime?
  implementedAt         DateTime?
  relatedServiceOrderId String?
  problemId             String?
  problem               ProblemRecord?  @relation(fields: [problemId], references: [id])
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([status])
  @@index([category])
  @@index([riskLevel])
  @@index([problemId])
  @@index([scheduledStartAt])
}

model PortalTicket {
  id             String   @id @default(uuid())
  trackingCode   String   @unique
  serviceOrderId String   @unique
  requesterName  String
  requesterEmail String
  requesterPhone String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([requesterEmail])
  @@index([createdAt])
}

enum GeoLocationSource {
  GPS
  MAP
  MANUAL
}

model ServiceOrderTemplate {
  id                  String    @id @default(uuid())
  name                String    @unique
  serviceTypeId       String
  titleTemplate       String
  descriptionTemplate String?
  defaultPriority     Priority?
  defaultDynamicData  Json?
  active              Boolean   @default(true)
  createdById         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([serviceTypeId, active])
}

model ServiceOrderClassificationRule {
  id             String   @id @default(uuid())
  name           String
  enabled        Boolean  @default(true)
  serviceTypeId  String?
  requesterRole  String?
  keywordPattern String
  priority       Priority
  category       String?
  subcategory    String?
  score          Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([enabled, serviceTypeId])
  @@index([requesterRole])
}

model ServiceOrderClassificationResult {
  id             String   @id @default(uuid())
  serviceOrderId String   @unique
  matchedRuleId  String?
  priority       Priority
  category       String?
  subcategory    String?
  reason         String?
  createdAt      DateTime @default(now())

  @@index([matchedRuleId])
}

model ServiceOrderDynamicFieldSchema {
  id            String   @id @default(uuid())
  serviceTypeId String
  fieldKey      String
  label         String
  fieldType     String
  required      Boolean  @default(false)
  options       Json?
  validation    Json?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([serviceTypeId, fieldKey])
  @@index([serviceTypeId, active])
}

model ServiceOrderDynamicFieldValue {
  id             String   @id @default(uuid())
  serviceOrderId String
  fieldKey       String
  value          Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([serviceOrderId, fieldKey])
  @@index([serviceOrderId])
}

model ServiceOrderHierarchy {
  id                   String   @id @default(uuid())
  parentServiceOrderId String
  childServiceOrderId  String   @unique
  createdAt            DateTime @default(now())

  @@unique([parentServiceOrderId, childServiceOrderId])
  @@index([parentServiceOrderId])
}

model ServiceOrderAssetLink {
  id                  String   @id @default(uuid())
  serviceOrderId      String
  assetId             String
  inheritedLocation   String?
  inheritedSlaId      String?
  inheritedContractId String?
  asset               Asset    @relation(fields: [assetId], references: [id])
  createdAt           DateTime @default(now())

  @@unique([serviceOrderId, assetId])
  @@index([assetId])
}

model ServiceOrderGeoLocation {
  id             String            @id @default(uuid())
  serviceOrderId String            @unique
  latitude       Decimal           @db.Decimal(10, 7)
  longitude      Decimal           @db.Decimal(10, 7)
  source         GeoLocationSource @default(MANUAL)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model ServiceOrderWorkflowTransition {
  id                 String             @id @default(uuid())
  serviceTypeId      String?
  fromStatus         ServiceOrderStatus
  toStatus           ServiceOrderStatus
  actionLabel        String
  autoAssign         Boolean            @default(false)
  startSlaTimer      Boolean            @default(false)
  triageAlertMinutes Int?
  active             Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([serviceTypeId, fromStatus, active])
  @@index([toStatus, active])
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

model WebhookSubscription {
  id             String            @id @default(uuid())
  eventType      String
  targetUrl      String
  secret         String?
  isActive       Boolean           @default(true)
  timeoutSeconds Int               @default(8)
  maxRetries     Int               @default(3)
  deliveries     WebhookDelivery[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([eventType, isActive])
}

model WebhookDelivery {
  id             String                @id @default(uuid())
  subscriptionId String
  eventType      String
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  attempt        Int                   @default(1)
  httpStatus     Int?
  responseBody   String?
  errorMessage   String?
  deliveredAt    DateTime?
  createdAt      DateTime              @default(now())
  subscription   WebhookSubscription   @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId, createdAt])
  @@index([eventType, status])
}

model TechnicianLocationPing {
  id        String   @id @default(uuid())
  userId    String
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal  @db.Decimal(10, 7)
  accuracyM Decimal? @db.Decimal(8, 2)
  source    String   @default("mobile")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/// MÓDULO 1+2+7: Extração automática de documentos (Parseur)
/// Registra cada extração com dados, confiança, validações e auditoria
model DocumentExtraction {
  id               String         @id @default(uuid())
  sourceType       String
  rawContent       String         @db.Text
  extractedData    Json
  fieldValidations Json
  overallConfidence Float          @default(0)
  isComplete       Boolean        @default(false)
  missingFields    String[]
  warnings         String[]
  mappedData       Json?
  autoProcessed    Boolean        @default(false)
  manuallyCorrectd Boolean        @default(false)
  correctedAt      DateTime?
  resolvedClientId String?
  serviceOrderId   String?
  createdById      String
  correctedById    String?
  createdAt        DateTime       @default(now())

  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
  createdBy    User          @relation("ExtractionCreatedBy", fields: [createdById], references: [id])
  correctedBy  User?         @relation("ExtractionCorrectedBy", fields: [correctedById], references: [id])

  @@index([sourceType])
  @@index([overallConfidence])
  @@index([autoProcessed])
  @@index([manuallyCorrectd])
  @@index([serviceOrderId])
  @@index([createdAt])
}
